{
  "expo": {
    "name": "TaskFlow",
    "slug": "rhino-taskflow-mobile",
    "scheme": "rhino-taskflow",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0a0e14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.rhinoproject.taskflow"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0e14"
      },
      "package": "org.rhinoproject.taskflow"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
